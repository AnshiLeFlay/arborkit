{
  "name": "@arborkit/sqlite",
  "version": "1.6.0-alpha.1",
  "description": "SQLite durable persistence and vector adapter for ArborKit",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public", "tag": "alpha" },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./sqlite-vec": { "types": "./dist/sqlite-vec.d.ts", "import": "./dist/sqlite-vec.js" }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "peerDependencies": { "arborkit": "1.6.0-alpha.1" },
  "dependencies": { "better-sqlite3": "^12.10.0" },
  "optionalDependencies": { "sqlite-vec": "^0.1.9" },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "arborkit": "file:../..",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
