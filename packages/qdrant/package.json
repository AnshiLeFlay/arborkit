{
  "name": "@arborkit/qdrant",
  "version": "1.6.0-alpha.1",
  "description": "Qdrant vector index adapter for ArborKit",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public", "tag": "alpha" },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
