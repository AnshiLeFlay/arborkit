  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepack": "npm run build"
  },
  "peerDependencies": { "arborkit": "1.6.0-alpha.1" },
  "dependencies": { "@qdrant/js-client-rest": "^1.15.1" },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "arborkit": "file:../..",
    "tsup": "^8.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
